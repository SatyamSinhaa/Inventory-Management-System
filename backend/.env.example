# ─── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql://ims_user:ims_password@localhost:5432/inventory_db

# ─── Kafka / Redpanda ─────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=inventory-events
KAFKA_GROUP_ID=inventory-consumer-group

# Cloud SASL configurations (optional for local Redpanda, required for Aiven/Upstash)
# KAFKA_SASL_USERNAME=avnadmin
# KAFKA_SASL_PASSWORD=your-sasl-password
# KAFKA_SASL_MECHANISM=scram-sha-256
# KAFKA_CA_CERT_PATH=ca.pem
# KAFKA_SSL_REJECT_UNAUTHORIZED=true
# KAFKA_CA_CERT= # Alternatively, paste the raw cert PEM string directly (useful for Render/Vercel)

# ─── Auth ─────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
